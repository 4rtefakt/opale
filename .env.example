# ── Serveur ────────────────────────────────────────────────────────────────────
PORT=3010
NODE_ENV=production

# ── Base de données ────────────────────────────────────────────────────────────
POSTGRES_DB=opale
POSTGRES_USER=opale
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db                    # nom du service Docker Compose, ou adresse IP

# ── Frontend ───────────────────────────────────────────────────────────────────
FRONTEND_URL=https://opale.example.com  # utilisé pour CORS
API_BASE_URL=/api                      # injecté dans window.ENV côté client

# ── Microsoft Entra ID (Azure AD) ─────────────────────────────────────────────
# App Registration avec permissions Application (pas déléguées) :
#   User.Read.All, Device.Read.All, DeviceManagementManagedDevices.Read.All,
#   GroupMember.Read.All
ENTRA_TENANT_ID=
ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=

# ── SSH ────────────────────────────────────────────────────────────────────────
# Clé privée ED25519 encodée en base64 : base64 -i ~/.ssh/id_ed25519
# Si non défini, l'API émet un warning au boot et utilise le défaut 'opale'.
SSH_USER=opale
SSH_PORT=22
SSH_PRIVATE_KEY_B64=

# ── Push notifications (PWA) ───────────────────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
# VAPID_EMAIL est REQUIS dès lors que les clés VAPID sont définies (fail-fast au boot).
# Format accepté : 'admin@example.com' ou 'mailto:admin@example.com'.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=

# ── Onboarding ─────────────────────────────────────────────────────────────────
# IDs des groupes Entra à assigner lors de l'onboarding (séparés par des virgules)
ONBOARDING_BASE_GROUP_IDS=
ONBOARDING_LICENSE_GROUP_ID=
